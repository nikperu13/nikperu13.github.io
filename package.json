{
  "name": "nikperu13-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:icons": "node ./scripts/generate-icon-sprite.mjs",
    "optimize:svg": "node ./scripts/optimize-svgs.mjs",
    "optimize:images": "node ./scripts/optimize-images.mjs",
    "build:assets": "npm run optimize:svg && npm run build:icons && npm run optimize:images",
    "build:resume": "esbuild scripts/generate-resume-site.ts --bundle --packages=external --platform=node --target=node24 --format=cjs --outfile=.cache/generate-resume-site.cjs && node .cache/generate-resume-site.cjs",
    "build:ts": "esbuild src/ts/site.ts src/ts/project.ts --bundle --format=iife --target=es2020 --outdir=assets/js",
    "watch:ts": "esbuild src/ts/site.ts src/ts/project.ts --bundle --format=iife --target=es2020 --outdir=assets/js --watch",
    "build": "npm run build:assets && npm run check:ts && npm run build:resume && npm run build:ts",
    "check:ts": "npm run check:ts:app && npm run check:ts:scripts",
    "check:ts:app": "tsc -p tsconfig.app.json --noEmit",
    "check:ts:scripts": "tsc -p tsconfig.scripts.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "animejs": "^4.3.6",
    "gsap": "^3.14.2",
    "lucide": "^0.577.0",
    "motion": "^12.35.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tsparticles": "^3.9.1"
  }
}
