{
  "name": "nikperu13-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:icons": "node ./scripts/generate-icon-sprite.mjs",
    "optimize:svg": "node ./scripts/optimize-svgs.mjs",
    "optimize:images": "node ./scripts/optimize-images.mjs",
    "build:assets": "npm run optimize:svg && npm run build:icons && npm run optimize:images",
    "build:ts": "esbuild src/ts/site.ts --bundle --format=iife --target=es2020 --outfile=assets/js/site.js",
    "watch:ts": "esbuild src/ts/site.ts --bundle --format=iife --target=es2020 --outfile=assets/js/site.js --watch",
    "build": "npm run build:assets && npm run check:ts && npm run build:ts",
    "check:ts": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "animejs": "^4.3.6",
    "gsap": "^3.14.2",
    "lucide": "^0.577.0",
    "motion": "^12.35.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1"
  }
}
