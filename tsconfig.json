{
  "compilerOptions": {
    "target": "ES2019",
    "module": "es2015",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jquery"],
    "typeRoots": ["./src/ts/types", "./node_modules/@types"],
    "outDir": "assets/js",
    "rootDir": "src/ts"
  },
  "include": ["src/ts/**/*.ts", "src/ts/**/*.d.ts"]
}
